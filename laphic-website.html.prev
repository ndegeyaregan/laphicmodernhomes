<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>LAPHIC Modern Homes — Architecture · Interiors · Landscapes | Kampala</title>
<meta name="description" content="LAPHIC Modern Homes is a Kampala-based architecture, interior and landscape studio crafting calm, modern Ugandan residences since 2012." />
<meta name="theme-color" content="#F4F0EA" />
<link rel="icon" href="images/logo.png" />
<meta property="og:title" content="LAPHIC Modern Homes" />
<meta property="og:description" content="Calm, modern Ugandan homes — architecture, interiors and landscapes since 2012." />
<meta property="og:image" content="images/projects/muyoyo.jpeg" />
<meta property="og:type" content="website" />
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"LocalBusiness","name":"LAPHIC Modern Homes","image":"images/logo.png","telephone":"+256780535307","email":"laphicmodernhomes@gmail.com","address":{"@type":"PostalAddress","addressLocality":"Kampala","addressCountry":"UG"},"foundingDate":"2012","sameAs":["https://instagram.com/laphichomes","https://x.com/laphichomes","https://www.tiktok.com/@laphic.modern.hom"]}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&family=Inter:wght@300;400;500;600&family=Syne:wght@500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bone:#F4F0EA;
  --cream:#EDE6DB;
  --sand:#E5DCCB;
  --ink:#1A1A1A;
  --char:#2A2826;
  --mute:#6B655C;
  --line:#D6CDBA;
  --terra:#C9A050;
  --terra-soft:#D9B86E;
  --olive:#5C5A3F;
  --gold:#A8864E;
  --white:#FFFFFF;
  --ease:cubic-bezier(0.22,1,0.36,1);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bone);color:var(--ink);font-family:'Inter',sans-serif;font-weight:400;font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
img,video{display:block;max-width:100%;height:auto}
a{color:inherit;text-decoration:none}
button{font:inherit;color:inherit;background:none;border:0;cursor:pointer}
.serif{font-family:'Fraunces',serif;font-weight:300;letter-spacing:-.01em}
.it{font-style:italic;font-weight:300}
.eyebrow{font-family:'Syne',sans-serif;font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.28em;color:var(--terra)}
.wrap{max-width:1480px;margin:0 auto;padding:0 50px;position:relative}
.kicker{display:flex;align-items:center;gap:14px;margin-bottom:24px}
.kicker i{width:36px;height:1px;background:var(--terra)}

/* Scroll progress */
#bar{position:fixed;top:0;left:0;height:2px;width:0;background:var(--terra);z-index:120;transition:width .15s linear}

/* Loader */
#loader{position:fixed;inset:0;background:var(--bone);z-index:9998;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:30px;transition:opacity .9s var(--ease),visibility .9s}
#loader.gone{opacity:0;visibility:hidden}
#loader .m{font-family:'Fraunces',serif;font-size:42px;font-weight:300;letter-spacing:.02em;color:var(--ink);overflow:hidden}
#loader .m span{display:inline-block;transform:translateY(110%);animation:rise 1s var(--ease) .1s forwards}
#loader .ln{width:160px;height:1px;background:var(--line);overflow:hidden}
#loader .ln i{display:block;height:100%;width:0;background:var(--terra);animation:fill 1.6s var(--ease) forwards}
@keyframes fill{to{width:100%}}
@keyframes rise{to{transform:translateY(0)}}

/* Nav */
.nav{position:fixed;top:0;left:0;right:0;z-index:90;padding:24px 0;transition:background .4s var(--ease),padding .4s var(--ease),box-shadow .4s,border-color .4s;border-bottom:1px solid transparent}
.nav.scrolled{background:rgba(244,240,234,.92);backdrop-filter:saturate(180%) blur(14px);-webkit-backdrop-filter:saturate(180%) blur(14px);padding:14px 0;border-bottom-color:var(--line)}
.nav .row{display:flex;align-items:center;justify-content:space-between;gap:30px}
.brand{display:flex;align-items:center;gap:12px}
.brand img{height:34px;width:auto}
.brand .nm{font-family:'Fraunces',serif;font-weight:400;font-size:22px;letter-spacing:.005em;color:#fff;transition:color .4s}
.brand .nm b{font-weight:500;color:var(--terra-soft);transition:color .4s}
.menu{display:flex;align-items:center;gap:34px}
.menu a{font-family:'Inter',sans-serif;font-weight:500;font-size:13px;letter-spacing:.04em;color:rgba(255,255,255,.88);position:relative;padding:6px 0;transition:color .4s}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:0;height:1px;background:var(--terra);transition:right .5s var(--ease)}
.menu a:hover::after{right:0}
.nav .cta{display:inline-flex;align-items:center;gap:10px;padding:12px 22px;border-radius:999px;background:#fff;color:var(--ink);font-size:12.5px;font-weight:500;letter-spacing:.02em;transition:background .35s,color .35s,transform .35s var(--ease)}
.nav .cta:hover{background:var(--terra);color:#fff;transform:translateY(-1px)}
.nav.scrolled .brand .nm{color:var(--ink)}
.nav.scrolled .brand .nm b{color:var(--terra)}
.nav.scrolled .menu a{color:var(--char)}
.nav.scrolled .cta{background:var(--ink);color:var(--bone)}
.nav.scrolled .cta:hover{background:var(--terra);color:#fff}
.nav.scrolled .burger span{background:var(--ink)}
.burger{display:none;width:28px;height:18px;position:relative}
.burger span{position:absolute;left:0;right:0;height:1.5px;background:#fff;transition:transform .4s var(--ease),opacity .3s,background .4s}
.burger span:nth-child(1){top:2px}
.burger span:nth-child(2){top:50%;transform:translateY(-50%)}
.burger span:nth-child(3){bottom:2px}
.burger.on span:nth-child(1){top:50%;transform:translateY(-50%) rotate(45deg)}
.burger.on span:nth-child(2){opacity:0}
.burger.on span:nth-child(3){bottom:50%;transform:translateY(50%) rotate(-45deg)}
.mpanel{position:fixed;inset:0;background:var(--bone);z-index:85;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;transition:opacity .5s var(--ease),visibility .5s}
.mpanel.on{opacity:1;visibility:visible}
.mpanel nav{display:flex;flex-direction:column;gap:18px;text-align:center}
.mpanel a{font-family:'Fraunces',serif;font-size:34px;font-weight:300;color:var(--ink)}
.mpanel a:hover{color:var(--terra)}

/* ===== HERO — full-bleed cinematic video ===== */
.hero{position:relative;min-height:100vh;height:100vh;width:100%;overflow:hidden;background:#0b0b0b;display:flex;align-items:flex-end}
.hero .bg{position:absolute;inset:0;z-index:0}
.hero .bg video,.hero .bg img{width:100%;height:100%;object-fit:cover;display:block}
.hero .bg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.55) 0%,rgba(0,0,0,.15) 35%,rgba(0,0,0,.25) 60%,rgba(0,0,0,.82) 100%);z-index:1}
.hero .bg::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at 30% 60%,rgba(0,0,0,.35),transparent 60%);z-index:1}
.hero .wrap{position:relative;z-index:2;width:100%;padding-top:160px;padding-bottom:60px}
.hero .grid{display:block}
.hero .right{display:none}
.hero .eyebrow{margin-bottom:30px;display:flex;align-items:center;gap:14px;color:rgba(255,255,255,.85)}
.hero .eyebrow::before{content:"";width:36px;height:1px;background:var(--terra)}
.hero h1{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,82px);line-height:1.02;letter-spacing:-.022em;color:#fff;max-width:900px;text-shadow:0 2px 30px rgba(0,0,0,.35)}
.hero h1 .li{display:block;overflow:hidden}
.hero h1 .li span{display:block;transform:translateY(110%);animation:rise 1.1s var(--ease) forwards}
.hero h1 .li:nth-child(2) span{animation-delay:.18s}
.hero h1 .li:nth-child(3) span{animation-delay:.34s}
.hero h1 em{font-style:italic;color:var(--terra-soft);font-weight:300}
.hero .sub{margin-top:34px;max-width:560px;font-size:16.5px;line-height:1.75;color:rgba(255,255,255,.82)}
.hero .actions{margin-top:40px;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
.hero .actions .btn.dark{background:#fff;color:var(--ink);border-color:#fff}
.hero .actions .btn.dark:hover{background:var(--terra);color:#fff;border-color:var(--terra)}
.hero .actions .btn.ghost{color:#fff;border-color:rgba(255,255,255,.45)}
.hero .actions .btn.ghost:hover{background:#fff;color:var(--ink);border-color:#fff}
.hero .scroll-hint{position:absolute;left:50%;bottom:28px;transform:translateX(-50%);z-index:3;color:rgba(255,255,255,.7);font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.32em;text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:10px}
.hero .scroll-hint .line{width:1px;height:42px;background:rgba(255,255,255,.5);animation:scrolldot 2s ease-in-out infinite}
@keyframes scrolldot{0%,100%{transform:scaleY(.3);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}}
.btn{display:inline-flex;align-items:center;gap:12px;padding:16px 30px;border-radius:999px;font-size:13px;font-weight:500;letter-spacing:.02em;transition:background .4s var(--ease),color .4s,transform .4s var(--ease),border-color .4s}
.btn.dark{background:var(--ink);color:var(--bone)}
.btn.dark:hover{background:var(--terra);transform:translateY(-2px)}
.btn.ghost{border:1px solid var(--ink);color:var(--ink)}
.btn.ghost:hover{background:var(--ink);color:var(--bone);transform:translateY(-2px)}
.btn .arr{transition:transform .4s var(--ease)}
.btn:hover .arr{transform:translateX(5px)}

.hero .right{position:relative}
.hero .right .main{position:relative;aspect-ratio:4/5;overflow:hidden;border-radius:6px;box-shadow:0 30px 80px -30px rgba(26,26,26,.25)}
.hero .right .main video,.hero .right .main img{width:100%;height:100%;object-fit:cover}
.hero .right .badge{position:absolute;left:-28px;bottom:-28px;background:var(--bone);padding:22px 26px;border-radius:4px;display:flex;align-items:center;gap:16px;box-shadow:0 16px 50px -20px rgba(26,26,26,.25);border:1px solid var(--line)}
.hero .right .badge .num{font-family:'Fraunces',serif;font-size:46px;font-weight:300;color:var(--terra);line-height:1}
.hero .right .badge .txt{font-size:12px;line-height:1.45;color:var(--char);max-width:120px}
.hero .right .tag{position:absolute;top:24px;right:24px;background:rgba(244,240,234,.92);backdrop-filter:blur(8px);padding:8px 14px;font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--ink);border-radius:999px}

.hero .meta{margin-top:60px;display:grid;grid-template-columns:repeat(4,1fr);gap:30px;padding-top:36px;border-top:1px solid rgba(255,255,255,.18);max-width:900px}
.hero .meta div .n{font-family:'Fraunces',serif;font-weight:400;font-size:32px;color:#fff;line-height:1}
.hero .meta div .n em{color:var(--terra-soft);font-style:normal}
.hero .meta div .l{margin-top:8px;font-size:12px;color:rgba(255,255,255,.7);letter-spacing:.04em}

/* ===== Marquee ===== */
.tape{padding:30px 0;background:var(--ink);color:var(--bone);overflow:hidden;white-space:nowrap;border-top:1px solid var(--char);border-bottom:1px solid var(--char)}
.tape .tk{display:inline-flex;gap:80px;animation:tk 38s linear infinite;padding-right:80px}
.tape span{font-family:'Fraunces',serif;font-weight:300;font-style:italic;font-size:30px;color:rgba(244,240,234,.85);display:inline-flex;align-items:center;gap:80px}
.tape span::after{content:"✦";color:var(--terra);font-style:normal;font-size:14px}
@keyframes tk{to{transform:translateX(-50%)}}

/* ===== About / Manifesto ===== */
.about{padding:160px 0;background:var(--bone)}
.about .grid{display:grid;grid-template-columns:.5fr 1fr;gap:80px;align-items:flex-start}
.about .left .eyebrow-row{display:flex;align-items:center;gap:14px;margin-bottom:24px}
.about .left .eyebrow-row::before{content:"";width:36px;height:1px;background:var(--terra)}
.about .left .num{font-family:'Fraunces',serif;font-size:88px;font-weight:300;color:var(--terra);line-height:1;font-style:italic}
.about .left p{margin-top:24px;font-size:14px;color:var(--mute);max-width:240px;line-height:1.7}
.about .right h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(36px,4.2vw,62px);line-height:1.1;color:var(--ink);letter-spacing:-.015em;max-width:880px}
.about .right h2 em{font-style:italic;color:var(--terra);font-weight:300}
.about .right .body{margin-top:60px;display:grid;grid-template-columns:1fr 1fr;gap:50px}
.about .right .body p{font-size:15.5px;line-height:1.85;color:var(--char)}
.about .signature{margin-top:60px;display:flex;align-items:center;gap:18px;color:var(--mute)}
.about .signature .l{font-family:'Fraunces',serif;font-style:italic;font-size:22px;color:var(--ink)}
.about .signature .r{font-size:12px;letter-spacing:.04em}

/* ===== Services — magazine ===== */
/* ===== STUDIO (services + featured project, merged) ===== */
.svc{padding:160px 0;background:var(--bone);position:relative;overflow:hidden}
.svc::before{content:"";position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--line),transparent)}
.svc .head{display:grid;grid-template-columns:1fr 1.1fr;gap:60px;align-items:end;margin-bottom:80px}
.svc h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,80px);line-height:1;color:var(--ink);letter-spacing:-.02em}
.svc h2 em{font-style:italic;color:var(--terra)}
.svc .head .desc{font-size:16px;line-height:1.8;color:var(--mute);max-width:520px;justify-self:end}
.svc .split{display:grid;grid-template-columns:1.15fr .85fr;gap:70px;align-items:start}

/* LEFT — featured project */
.svc .feature{position:relative}
.svc .feature .vis{position:relative;aspect-ratio:4/4.6;overflow:hidden;border-radius:6px;box-shadow:0 30px 80px -30px rgba(26,26,26,.28)}
.svc .feature .vis img{width:100%;height:100%;object-fit:cover;transition:transform 12s linear}
.svc .feature:hover .vis img{transform:scale(1.05)}
.svc .feature .tag{position:absolute;top:22px;left:22px;z-index:2;background:rgba(244,240,234,.95);backdrop-filter:blur(8px);padding:9px 16px;font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--ink);border-radius:999px}
.svc .feature .info{margin-top:36px;display:flex;flex-direction:column;gap:18px}
.svc .feature .title-row{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap}
.svc .feature h3{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(32px,3.4vw,46px);line-height:1;color:var(--ink);letter-spacing:-.018em}
.svc .feature h3 em{font-style:italic;color:var(--terra)}
.svc .feature .link{display:inline-flex;align-items:center;gap:10px;font-size:13px;letter-spacing:.03em;color:var(--ink);padding-bottom:4px;border-bottom:1px solid var(--ink);transition:color .35s,border-color .35s,transform .4s var(--ease)}
.svc .feature .link:hover{color:var(--terra);border-color:var(--terra);transform:translateX(4px)}
.svc .feature .lede{font-size:15.5px;line-height:1.8;color:var(--char);max-width:560px}
.svc .feature .specs{margin-top:14px;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;padding-top:24px;border-top:1px solid var(--line)}
.svc .feature .specs div .l{font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.26em;color:var(--terra);text-transform:uppercase;margin-bottom:8px;display:block}
.svc .feature .specs div .v{font-family:'Fraunces',serif;font-size:16px;color:var(--ink);font-weight:400;line-height:1.3}

/* RIGHT — services list */
.svc .services{position:relative;padding-left:0}
.svc .services .label{display:inline-flex;align-items:center;gap:12px;font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--mute);margin-bottom:32px}
.svc .services .label::before{content:"";width:24px;height:1px;background:var(--terra)}
.svc .slist{list-style:none;border-top:1px solid var(--line)}
.svc .slist li{border-bottom:1px solid var(--line)}
.svc .slist li a{display:grid;grid-template-columns:50px 1fr 38px;align-items:center;gap:18px;padding:24px 0;transition:padding .45s var(--ease),color .35s}
.svc .slist .n{font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.24em;color:var(--terra);font-weight:600}
.svc .slist .t{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(22px,2vw,30px);line-height:1.05;color:var(--ink);letter-spacing:-.012em;transition:color .35s,transform .5s var(--ease)}
.svc .slist .t em{font-style:italic;color:var(--terra)}
.svc .slist .ar{display:inline-flex;width:36px;height:36px;border-radius:50%;border:1px solid var(--line);align-items:center;justify-content:center;color:var(--ink);font-size:14px;transition:background .35s,color .35s,border-color .35s,transform .4s var(--ease)}
.svc .slist li:hover a{padding-left:14px}
.svc .slist li:hover .t{color:var(--terra)}
.svc .slist li:hover .ar{background:var(--terra);border-color:var(--terra);color:#fff;transform:rotate(-45deg)}
.svc .all-link{display:inline-flex;align-items:center;gap:10px;margin-top:36px;font-size:12.5px;font-weight:500;letter-spacing:.04em;color:var(--ink);padding:14px 24px;border:1px solid var(--ink);border-radius:999px;transition:background .35s,color .35s,transform .4s var(--ease)}
.svc .all-link:hover{background:var(--ink);color:var(--bone);transform:translateY(-2px)}
.svc .head{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:end;margin-bottom:70px}
.svc h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,80px);line-height:1;color:var(--ink);letter-spacing:-.02em}
.svc h2 em{font-style:italic;color:var(--terra)}
.svc .head .desc{font-size:16px;line-height:1.8;color:var(--mute);max-width:520px;justify-self:end}

/* ===== Stats ===== */
.stats{padding:44px 0;background:var(--ink);color:var(--bone)}
.stats .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
.stats .cell{padding:10px 16px;border-left:1px solid rgba(244,240,234,.12);text-align:left}
.stats .cell:first-child{border-left:0;padding-left:0}
.stats .cell .n{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(24px,2.4vw,34px);line-height:1;color:var(--terra-soft);letter-spacing:-.01em}
.stats .cell .l{margin-top:6px;font-family:'Syne',sans-serif;font-size:9px;letter-spacing:.24em;text-transform:uppercase;color:rgba(244,240,234,.65)}
.stats .cell .d{margin-top:4px;font-size:11px;color:rgba(244,240,234,.5);max-width:200px;line-height:1.45}

/* ===== Portfolio Grid ===== */
.port{padding:140px 0;background:var(--bone)}
.port .head{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:64px}
.port h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,80px);line-height:1;color:var(--ink);letter-spacing:-.02em}
.port h2 em{font-style:italic;color:var(--terra)}
.port .head .right{display:flex;justify-content:flex-end;align-items:end;gap:30px}
.port .filters{display:flex;gap:4px;flex-wrap:wrap;border-bottom:1px solid var(--line)}
.port .filters button{position:relative;padding:10px 18px 14px;border:0;background:transparent;font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--mute);font-weight:500;cursor:pointer;transition:color .35s var(--ease)}
.port .filters button::after{content:"";position:absolute;left:18px;right:18px;bottom:-1px;height:2px;background:var(--terra);transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease)}
.port .filters button:hover,.port .filters button.on{color:var(--ink)}
.port .filters button.on::after{transform:scaleX(1)}

.port .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:48px 32px}
.port .card{position:relative;grid-column:span 4;display:block;text-decoration:none;color:inherit}
.port .card.lg{grid-column:span 12}
.port .card.md{grid-column:span 6}
.port .card.eq{grid-column:span 4}

.port .card .vis{position:relative;overflow:hidden;background:var(--cream);aspect-ratio:4/5;isolation:isolate}
.port .card.lg .vis{aspect-ratio:21/10}
.port .card.md .vis{aspect-ratio:5/4}
.port .card .vis img{width:100%;height:100%;object-fit:cover;transition:transform 2s cubic-bezier(.16,1,.3,1),filter .8s var(--ease);display:block;filter:saturate(.92) contrast(1.02)}
.port .card:hover .vis img{transform:scale(1.07);filter:saturate(1.05) contrast(1.04)}

/* Dark veil reveal */
.port .card .vis::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,10,10,.05) 0%,transparent 40%,transparent 55%,rgba(10,10,10,.55) 100%);opacity:0;transition:opacity .6s var(--ease);z-index:1;pointer-events:none}
.port .card:hover .vis::before{opacity:1}

/* Corner architectural marks */
.port .card .vis::after{content:"";position:absolute;top:14px;left:14px;width:22px;height:22px;border-top:1px solid var(--terra);border-left:1px solid var(--terra);opacity:0;transition:opacity .5s var(--ease) .05s, transform .5s var(--ease);transform:translate(6px,6px);z-index:2;pointer-events:none}
.port .card:hover .vis::after{opacity:1;transform:translate(0,0)}
.port .card .vis .cm{position:absolute;bottom:14px;right:14px;width:22px;height:22px;border-bottom:1px solid var(--terra);border-right:1px solid var(--terra);opacity:0;transition:opacity .5s var(--ease) .05s, transform .5s var(--ease);transform:translate(-6px,-6px);z-index:2;pointer-events:none}
.port .card:hover .vis .cm{opacity:1;transform:translate(0,0)}

/* Gold "VIEW" tag */
.port .card .tag{position:absolute;top:0;right:0;background:var(--terra);color:#0d0d12;font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.32em;font-weight:600;text-transform:uppercase;padding:10px 18px;z-index:3;opacity:0;transform:translateY(-100%);transition:transform .55s cubic-bezier(.7,0,.2,1) .05s, opacity .35s var(--ease)}
.port .card:hover .tag{opacity:1;transform:translateY(0)}

/* Featured giant number watermark on image */
.port .card.lg .num{position:absolute;left:36px;bottom:24px;font-family:'Fraunces',serif;font-weight:200;font-style:italic;font-size:clamp(80px,12vw,170px);line-height:.85;color:#fff;mix-blend-mode:overlay;z-index:2;letter-spacing:-.04em;pointer-events:none;opacity:.95}

/* Meta below image — editorial two-column */
.port .card .meta{display:grid;grid-template-columns:64px 1fr auto;gap:20px;padding-top:22px;align-items:start;border-top:1px solid var(--line);margin-top:0;position:relative}
.port .card .meta::before{content:"";position:absolute;top:-1px;left:0;width:48px;height:1px;background:var(--ink);transition:width .6s var(--ease)}
.port .card:hover .meta::before{width:100%;background:var(--terra)}
.port .card .meta .no{font-family:'Fraunces',serif;font-weight:300;font-style:italic;font-size:30px;line-height:1;color:var(--terra);letter-spacing:-.02em}
.port .card .meta .l{min-width:0}
.port .card .meta .cat{font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--mute);margin-bottom:8px}
.port .card .meta .ttl{font-family:'Fraunces',serif;font-weight:400;font-size:clamp(20px,1.55vw,24px);line-height:1.2;color:var(--ink);letter-spacing:-.01em;transition:color .35s var(--ease)}
.port .card .meta .ttl em{font-style:italic;color:var(--terra);font-weight:300}
.port .card.lg .meta .ttl{font-size:clamp(28px,2.4vw,38px);font-weight:300}
.port .card:hover .meta .ttl{color:var(--terra)}
.port .card .meta .arr{flex:0 0 auto;width:40px;height:40px;border-radius:50%;border:1px solid var(--line);display:grid;place-items:center;color:var(--ink);font-size:14px;transition:all .4s var(--ease);transform:translateY(2px)}
.port .card:hover .meta .arr{background:var(--terra);border-color:var(--terra);color:#0d0d12;transform:translateY(2px) rotate(-45deg)}

.port .card.hidden{display:none}
.port .more{margin-top:80px;text-align:center}

/* ===== Quote callout ===== */
.quote{padding:140px 0;background:var(--cream);text-align:center}
.quote p{font-family:'Fraunces',serif;font-weight:300;font-style:italic;font-size:clamp(28px,3.8vw,52px);line-height:1.25;color:var(--ink);max-width:1100px;margin:0 auto;letter-spacing:-.01em}
.quote p em{color:var(--terra)}
.quote .who{margin-top:50px;font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.3em;color:var(--mute);text-transform:uppercase}

/* ===== Materials ===== */
.mat{padding:160px 0;background:var(--bone)}
.mat .head{display:grid;grid-template-columns:1fr 1.1fr;gap:60px;align-items:end;margin-bottom:70px}
.mat h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,76px);line-height:1;color:var(--ink);letter-spacing:-.02em}
.mat h2 em{font-style:italic;color:var(--terra)}
.mat .head p{font-size:16px;line-height:1.8;color:var(--mute);max-width:500px;justify-self:end}
.mat .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.mat .card{background:var(--cream);padding:0;border-radius:6px;overflow:hidden;transition:transform .55s var(--ease),box-shadow .55s}
.mat .card:hover{transform:translateY(-8px);box-shadow:0 30px 60px -25px rgba(26,26,26,.18)}
.mat .card .ph{aspect-ratio:4/3;overflow:hidden;background:var(--sand)}
.mat .card .ph img{width:100%;height:100%;object-fit:cover;transition:transform 1.4s var(--ease)}
.mat .card:hover .ph img{transform:scale(1.06)}
.mat .card .body{padding:34px 30px 36px}
.mat .card .n{font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.28em;color:var(--terra);font-weight:600;margin-bottom:18px}
.mat .card h3{font-family:'Fraunces',serif;font-weight:400;font-size:30px;line-height:1.1;color:var(--ink);margin-bottom:14px;letter-spacing:-.01em}
.mat .card p{font-size:14.5px;line-height:1.75;color:var(--mute)}
.mat .card .row{margin-top:24px;padding-top:18px;border-top:1px solid var(--line);display:flex;justify-content:space-between;font-size:11.5px;color:var(--char);font-weight:500;letter-spacing:.02em}

/* ===== Process ===== */
.proc{padding:160px 0;background:var(--ink);color:var(--bone)}
.proc .head{margin-bottom:80px;max-width:880px}
.proc .head .eyebrow{color:var(--terra-soft)}
.proc h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,80px);line-height:1.04;color:var(--bone);letter-spacing:-.02em;margin-top:24px}
.proc h2 em{font-style:italic;color:var(--terra-soft)}
.proc .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}
.proc .step{padding:34px 28px;background:rgba(244,240,234,.04);border:1px solid rgba(244,240,234,.08);border-radius:6px;transition:background .4s,transform .4s var(--ease),border-color .4s}
.proc .step:hover{background:rgba(201,160,80,.08);border-color:var(--terra);transform:translateY(-6px)}
.proc .step .n{font-family:'Fraunces',serif;font-size:60px;font-weight:300;color:var(--terra-soft);line-height:1;letter-spacing:-.03em;font-style:italic}
.proc .step h3{font-family:'Fraunces',serif;font-weight:400;font-size:26px;color:var(--bone);margin:22px 0 14px;letter-spacing:-.01em}
.proc .step p{font-size:14px;line-height:1.7;color:rgba(244,240,234,.65)}

/* ===== Process flow diagram (replaces 3rd col below) ===== */

/* ===== Awards ===== */
.aw{padding:140px 0;background:var(--cream)}
.aw .head{margin-bottom:60px;text-align:center}
.aw h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5vw,72px);line-height:1;color:var(--ink);letter-spacing:-.02em}
.aw h2 em{font-style:italic;color:var(--terra)}
.aw .head .kicker{justify-content:center}
.aw .list{display:grid;grid-template-columns:repeat(4,1fr)}
.aw .item{padding:36px 26px;border-left:1px solid var(--line);border-bottom:1px solid var(--line);transition:background .4s}
.aw .item:nth-child(4n+1){border-left:0}
.aw .item:nth-child(-n+4){border-top:1px solid var(--line)}
.aw .item:hover{background:var(--bone)}
.aw .item .y{font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.28em;color:var(--terra);margin-bottom:14px;font-weight:600}
.aw .item .t{font-family:'Fraunces',serif;font-weight:400;font-size:22px;color:var(--ink);line-height:1.2;margin-bottom:8px;letter-spacing:-.005em}
.aw .item .b{font-size:13px;color:var(--mute);letter-spacing:.02em}

/* ===== Testimonials ===== */
.tst{padding:140px 0;background:var(--ink);color:var(--bone);position:relative;overflow:hidden}
.tst::before{content:"\201C";position:absolute;top:60px;right:6%;font-family:'Fraunces',serif;font-style:italic;font-weight:300;font-size:clamp(280px,32vw,520px);line-height:.7;color:var(--terra);opacity:.07;pointer-events:none;z-index:0}
.tst .wrap{position:relative;z-index:1}
.tst .head{margin-bottom:64px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end}
.tst .kicker i{background:var(--terra)}
.tst .eyebrow{color:rgba(244,240,234,.7)}
.tst h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5vw,72px);line-height:1;color:var(--bone);letter-spacing:-.02em}
.tst h2 em{font-style:italic;color:var(--terra)}
.tst .nav-btns{display:flex;justify-content:flex-end;align-items:center;gap:24px}
.tst .nav-btns .count{font-family:'Fraunces',serif;font-style:italic;font-weight:300;font-size:34px;color:rgba(244,240,234,.55);letter-spacing:-.01em}
.tst .nav-btns .count b{color:var(--terra);font-weight:300;margin-right:6px}
.tst .nav-btns .count s{text-decoration:none;color:rgba(244,240,234,.35);margin-left:6px}
.tst .nav-btns .btns{display:flex;gap:10px}
.tst .nav-btns button{width:48px;height:48px;border-radius:50%;border:1px solid rgba(244,240,234,.25);background:transparent;color:var(--bone);font-size:14px;transition:all .35s var(--ease);cursor:pointer}
.tst .nav-btns button:hover{background:var(--terra);color:#0d0d12;border-color:var(--terra)}

.tst .stage{display:grid;grid-template-columns:.85fr 1.15fr;gap:80px;align-items:center;max-width:1300px;margin:0 auto;min-height:420px;position:relative}
.tst .stage .ph{position:relative;aspect-ratio:4/5;overflow:hidden;background:#222}
.tst .stage .ph::after{content:"";position:absolute;inset:0;border:1px solid rgba(201,160,80,.18);pointer-events:none;margin:14px}
.tst .stage .ph .pi{position:absolute;inset:0;opacity:0;transition:opacity .8s var(--ease),transform 1.6s var(--ease);transform:scale(1.05)}
.tst .stage .ph .pi.on{opacity:1;transform:scale(1)}
.tst .stage .ph .pi img{width:100%;height:100%;object-fit:cover;display:block;filter:saturate(.85) brightness(.85)}

.tst .slider{position:relative;min-height:340px}
.tst .slide{position:absolute;inset:0;opacity:0;transform:translateY(20px);transition:opacity .7s var(--ease),transform .7s var(--ease);pointer-events:none}
.tst .slide.on{opacity:1;transform:none;pointer-events:auto}
.tst .stars{color:var(--terra);font-size:13px;letter-spacing:.5em;margin-bottom:26px}
.tst .q{font-family:'Fraunces',serif;font-weight:300;font-style:italic;font-size:clamp(22px,2.3vw,32px);line-height:1.45;color:var(--bone);letter-spacing:-.005em}
.tst .q::before{content:"\201C";font-size:1.2em;color:var(--terra);margin-right:6px;line-height:0;position:relative;top:.18em}
.tst .q::after{content:"\201D";font-size:1.2em;color:var(--terra);margin-left:4px;line-height:0;position:relative;top:.18em}
.tst .who{margin-top:42px;display:flex;align-items:center;gap:18px;padding-top:24px;border-top:1px solid rgba(244,240,234,.12);max-width:520px}
.tst .who::before{content:"";position:absolute;width:64px;height:1px;background:var(--terra);margin-top:-25px}
.tst .who .av{width:54px;height:54px;border-radius:50%;background:var(--terra);color:#0d0d12;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;letter-spacing:.05em;flex:0 0 auto}
.tst .who .n{font-family:'Fraunces',serif;font-size:20px;color:var(--bone);font-weight:400}
.tst .who .r{display:block;font-family:'Syne',sans-serif;font-size:10px;color:var(--terra-soft);letter-spacing:.28em;margin-top:6px;text-transform:uppercase}

.tst .strip{margin-top:70px;display:flex;justify-content:center;gap:18px;flex-wrap:wrap}
.tst .dot{position:relative;display:flex;align-items:center;gap:10px;padding:10px 18px;border:1px solid rgba(244,240,234,.15);background:transparent;color:rgba(244,240,234,.5);font-family:'Syne',sans-serif;font-size:10px;letter-spacing:.22em;text-transform:uppercase;cursor:pointer;transition:all .35s var(--ease)}
.tst .dot b{font-family:'Fraunces',serif;font-style:italic;font-weight:300;font-size:18px;color:var(--terra-soft);letter-spacing:0}
.tst .dot:hover{color:var(--bone);border-color:rgba(244,240,234,.4)}
.tst .dot.on{background:var(--terra);color:#0d0d12;border-color:var(--terra)}
.tst .dot.on b{color:#0d0d12}

/* ===== Journal / Inspirations ===== */
.jrn{padding:160px 0;background:var(--cream)}
.jrn .head{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:60px}
.jrn h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,5.4vw,76px);line-height:1;color:var(--ink);letter-spacing:-.02em}
.jrn h2 em{font-style:italic;color:var(--terra)}
.jrn .head .r{display:flex;justify-content:flex-end;align-items:end}
.jrn .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.jrn .post{cursor:pointer}
.jrn .post .ph{aspect-ratio:5/4;overflow:hidden;border-radius:4px;background:var(--sand);margin-bottom:22px}
.jrn .post .ph img{width:100%;height:100%;object-fit:cover;transition:transform 1.4s var(--ease)}
.jrn .post:hover .ph img{transform:scale(1.06)}
.jrn .post .meta{display:flex;gap:14px;font-family:'Syne',sans-serif;font-size:10.5px;letter-spacing:.24em;color:var(--terra);text-transform:uppercase;margin-bottom:12px;font-weight:600}
.jrn .post .meta .dot{color:var(--mute)}
.jrn .post h3{font-family:'Fraunces',serif;font-weight:400;font-size:26px;line-height:1.2;color:var(--ink);letter-spacing:-.01em;transition:color .35s}
.jrn .post:hover h3{color:var(--terra)}
.jrn .post p{margin-top:12px;font-size:14.5px;line-height:1.7;color:var(--mute)}

/* ===== FAQ ===== */
.faq{padding:160px 0;background:var(--bone)}
.faq .grid{display:grid;grid-template-columns:.85fr 1.4fr;gap:80px;align-items:start}
.faq h2{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(40px,4.8vw,68px);line-height:1.04;color:var(--ink);letter-spacing:-.02em}
.faq h2 em{font-style:italic;color:var(--terra)}
.faq .left p{margin-top:24px;font-size:15px;line-height:1.8;color:var(--mute);max-width:340px}
.faq .left .btn{margin-top:34px}
.faq .list{border-top:1px solid var(--line)}
.faq .q{border-bottom:1px solid var(--line);padding:28px 0;cursor:pointer}
.faq .q .h{display:flex;justify-content:space-between;align-items:center;gap:30px}
.faq .q .h h3{font-family:'Fraunces',serif;font-weight:400;font-size:clamp(20px,2vw,26px);color:var(--ink);transition:color .35s;letter-spacing:-.01em}
.faq .q.on .h h3{color:var(--terra)}
.faq .pl{position:relative;width:22px;height:22px;flex:0 0 22px}
.faq .pl::before,.faq .pl::after{content:"";position:absolute;background:var(--ink);transition:transform .4s var(--ease),background .35s}
.faq .pl::before{top:50%;left:0;right:0;height:1.5px;transform:translateY(-50%)}
.faq .pl::after{left:50%;top:0;bottom:0;width:1.5px;transform:translateX(-50%)}
.faq .q.on .pl::before,.faq .q.on .pl::after{background:var(--terra)}
.faq .q.on .pl::after{transform:translateX(-50%) scaleY(0)}
.faq .a{max-height:0;overflow:hidden;transition:max-height .55s var(--ease)}
.faq .a p{padding:18px 60px 6px 0;font-size:15px;line-height:1.8;color:var(--mute);max-width:780px}

/* ===== CTA / Contact ===== */
.cta{padding:180px 0;background:var(--ink);color:var(--bone);text-align:center;position:relative;overflow:hidden}
.cta::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(201,160,80,.22),transparent 65%);pointer-events:none}
.cta h2{position:relative;font-family:'Fraunces',serif;font-weight:300;font-size:clamp(48px,7vw,120px);line-height:.96;color:var(--bone);letter-spacing:-.025em}
.cta h2 em{font-style:italic;color:var(--terra-soft)}
.cta .actions{position:relative;margin-top:50px;display:flex;justify-content:center;gap:18px;flex-wrap:wrap}
.cta .btn.dark{background:var(--terra);color:var(--bone)}
.cta .btn.dark:hover{background:var(--bone);color:var(--ink)}
.cta .btn.ghost{border-color:var(--bone);color:var(--bone)}
.cta .btn.ghost:hover{background:var(--bone);color:var(--ink)}
.cta .contact-row{position:relative;margin-top:80px;padding-top:40px;border-top:1px solid rgba(244,240,234,.15);display:grid;grid-template-columns:repeat(3,1fr);gap:40px;text-align:left}
.cta .contact-row .l{font-family:'Syne',sans-serif;font-size:10.5px;letter-spacing:.3em;color:var(--terra-soft);margin-bottom:12px;text-transform:uppercase}
.cta .contact-row .v{font-family:'Fraunces',serif;font-size:22px;color:var(--bone);font-weight:400}
.cta .contact-row a:hover{color:var(--terra-soft)}

/* ===== Footer ===== */
footer{background:var(--bone);padding:90px 0 30px;border-top:1px solid var(--line)}
footer .grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:60px;margin-bottom:60px}
footer .col h4{font-family:'Syne',sans-serif;font-size:11px;letter-spacing:.28em;color:var(--terra);text-transform:uppercase;margin-bottom:24px;font-weight:600}
footer .col a,footer .col p{display:block;font-size:14px;line-height:1.95;color:var(--char);transition:color .3s}
footer .col a:hover{color:var(--terra)}
footer .brand{display:flex;align-items:center;gap:14px;margin-bottom:22px}
footer .brand img{height:38px}
footer .brand .nm{font-family:'Fraunces',serif;font-weight:400;font-size:24px;color:var(--ink)}
footer .brand .nm b{color:var(--terra);font-weight:500}
footer .about-col p{max-width:340px;font-size:14.5px;line-height:1.8;color:var(--mute)}
footer .socials{display:flex;gap:12px;margin-top:24px}
footer .socials a{width:42px;height:42px;border:1px solid var(--line);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--ink);transition:background .4s,color .4s,border-color .4s}
footer .socials a:hover{background:var(--ink);color:var(--bone);border-color:var(--ink)}
footer .bot{padding-top:30px;border-top:1px solid var(--line);display:flex;justify-content:space-between;flex-wrap:wrap;gap:14px;font-size:12px;color:var(--mute);letter-spacing:.02em}
footer .bot b{color:var(--ink);font-weight:600}

/* Reveals */
.sr,.sl,.srr,.clip{opacity:0;transition:opacity 1s var(--ease),transform 1.2s var(--ease),clip-path 1.4s var(--ease)}
.sr{transform:translateY(30px)}
.sl{transform:translateX(-30px)}
.srr{transform:translateX(30px)}
.clip{clip-path:inset(0 0 100% 0)}
.sr.v,.sl.v,.srr.v{opacity:1;transform:none}
.clip.v{opacity:1;clip-path:inset(0 0 0 0)}

/* Responsive */
@media (max-width:1100px){
  .svc .split{grid-template-columns:1fr;gap:60px}
  .svc .feature .specs{grid-template-columns:repeat(2,1fr)}
  .about .grid{grid-template-columns:1fr;gap:30px}
  .about .right .body{grid-template-columns:1fr}
  .stats .grid{grid-template-columns:repeat(2,1fr);gap:30px}
  .stats .cell{border-left:0;border-top:1px solid rgba(244,240,234,.12);padding:30px 0}
  .stats .cell:first-child,.stats .cell:nth-child(2){border-top:0}
  .proc .steps{grid-template-columns:repeat(2,1fr)}
  .mat .grid{grid-template-columns:1fr;gap:24px}
  .jrn .grid{grid-template-columns:1fr;gap:40px}
  .aw .list{grid-template-columns:repeat(2,1fr)}
  .aw .item:nth-child(4n+1){border-left:1px solid var(--line)}
  .aw .item:nth-child(2n+1){border-left:0}
  .aw .item:nth-child(-n+2){border-top:1px solid var(--line)}
  .aw .item:nth-child(3),.aw .item:nth-child(4){border-top:0}
  .port .grid{grid-template-columns:repeat(6,1fr);gap:28px 22px}
  .port .card,.port .card.eq{grid-column:span 3}
  .port .card.lg{grid-column:span 6}
  .port .card.md{grid-column:span 3}
  .tst .stage{grid-template-columns:1fr;gap:50px}
  .tst .stage .ph{aspect-ratio:16/10;max-width:520px}
  .faq .grid{grid-template-columns:1fr;gap:40px}
  footer .grid{grid-template-columns:1fr 1fr;gap:40px}
}
@media (max-width:900px){
  .wrap{padding:0 24px}
  .menu,.nav .cta{display:none}
  .burger{display:block}
  .hero{min-height:90vh;height:auto}
  .hero .wrap{padding-top:130px;padding-bottom:80px}
  .hero .meta{grid-template-columns:repeat(2,1fr);margin-top:50px}
  .about,.svc,.port,.mat,.proc,.aw,.tst,.jrn,.faq,.cta,.quote{padding:90px 0}
  .svc .feature .specs{grid-template-columns:1fr 1fr}
  .svc .head,.port .head,.tst .head,.jrn .head,.mat .head{grid-template-columns:1fr;gap:24px}
  .port .head .right{justify-content:flex-start}
  .port .card.lg .vis{aspect-ratio:16/10}
  .cta .contact-row{grid-template-columns:1fr}
}
@media (max-width:600px){
  footer .grid{grid-template-columns:1fr}
  .port .grid{grid-template-columns:repeat(2,1fr);gap:32px 18px}
  .port .card,.port .card.lg,.port .card.md,.port .card.eq{grid-column:span 2}
  .port .card .vis,.port .card.lg .vis,.port .card.md .vis{aspect-ratio:4/3}
}
</style>
</head>
