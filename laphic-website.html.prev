<script>
(function(){
  // Loader
  window.addEventListener('load', function(){ setTimeout(function(){ document.getElementById('loader').classList.add('gone'); }, 1500); });

  // Nav scroll + progress bar
  var nav = document.getElementById('nav'), bar = document.getElementById('bar');
  function onScroll(){
    var y = window.scrollY;
    nav.classList.toggle('scrolled', y>40);
    var h = document.documentElement.scrollHeight - window.innerHeight;
    bar.style.width = ((y/h)*100)+'%';
  }
  window.addEventListener('scroll', onScroll, {passive:true}); onScroll();

  // Burger
  var burger = document.querySelector('.burger'), panel = document.getElementById('mpanel');
  if(burger){
    burger.addEventListener('click', function(){ burger.classList.toggle('on'); panel.classList.toggle('on'); });
    panel.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', function(){ burger.classList.remove('on'); panel.classList.remove('on'); }); });
  }

  // Reveals
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('v'); io.unobserve(e.target); } });
  },{threshold:.12});
  document.querySelectorAll('.sr,.sl,.srr,.clip').forEach(function(el){ io.observe(el); });

  // Count up
  var counted = false;
  var nums = document.querySelectorAll('[data-target]');
  if(nums.length){
    var sect = nums[0].closest('.stats');
    new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting && !counted){
          counted = true;
          nums.forEach(function(n){
            var t = +n.dataset.target, suf = n.dataset.suf || '', c=0, step = Math.max(1, Math.ceil(t/60));
            var iv = setInterval(function(){ c+=step; if(c>=t){c=t; clearInterval(iv);} n.textContent = c + suf; }, 28);
          });
        }
      });
    },{threshold:.3}).observe(sect);
  }

  // Testimonials
  var slides = document.querySelectorAll('#slider .slide'), dots = document.querySelectorAll('#dots .dot'), pics = document.querySelectorAll('.tst .stage .ph .pi'), cur = document.getElementById('tCur'), i=0, autoT;
  function go(n){ i = (n+slides.length)%slides.length; slides.forEach(function(s,k){ s.classList.toggle('on',k===i); }); dots.forEach(function(d,k){ d.classList.toggle('on',k===i); }); pics.forEach(function(p,k){ p.classList.toggle('on',k===i); }); if(cur) cur.textContent = (i+1).toString().padStart(2,'0'); }
  dots.forEach(function(d){ d.addEventListener('click', function(){ go(+d.dataset.i); reset(); }); });
  document.getElementById('prev').addEventListener('click', function(){ go(i-1); reset(); });
  document.getElementById('next').addEventListener('click', function(){ go(i+1); reset(); });
  function reset(){ clearInterval(autoT); autoT=setInterval(function(){ go(i+1); }, 6500); }
  if(slides.length){ autoT=setInterval(function(){ go(i+1); }, 6500); }

  // Portfolio filters
  var fbtns = document.querySelectorAll('.port .filters button');
  fbtns.forEach(function(b){
    b.addEventListener('click', function(){
      fbtns.forEach(function(x){ x.classList.remove('on'); });
      b.classList.add('on');
      var f = b.dataset.f;
      document.querySelectorAll('#pgrid .card').forEach(function(c){
        if(f==='all' || c.dataset.c===f){ c.style.display=''; }
        else{ c.style.display='none'; }
      });
    });
  });

  // FAQ
  document.querySelectorAll('#faq .q').forEach(function(q){
    q.addEventListener('click', function(){
      var on = q.classList.toggle('on');
      var a = q.querySelector('.a');
      a.style.maxHeight = on ? a.scrollHeight+'px' : '0';
    });
  });
  // Open first FAQ initially
  var first = document.querySelector('#faq .q.on .a'); if(first){ first.style.maxHeight = first.scrollHeight+'px'; }

  // Year
  var yr = document.getElementById('yr'); if(yr) yr.textContent = new Date().getFullYear();
})();
</script>
</body>
</html>
